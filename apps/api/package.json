{
	"name": "api",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "ts-node-dev --respawn --transpile-only src/server.ts",
		"build": "tsc",
		"db:generate": "prisma generate",
		"db:sync": "prisma db push",
		"seeds": "ts-node-dev --transpile-only prisma/seeds/index.ts",
		"lint": "biome check . --write",
		"format": "biome format . --write",
		"start": "node dist/server.js"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@prisma/extension-accelerate": "^3.0.1",
		"bcryptjs": "^3.0.3",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"dotenv": "^16.0.3",
		"express": "^5.2.1",
		"express-rate-limit": "^8.5.2",
		"helmet": "^8.2.0",
		"jsonwebtoken": "^9.0.3",
		"slugify": "^1.6.9",
		"winston": "^3.19.0",
		"winston-daily-rotate-file": "^5.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^22.20.1",
		"prisma": "^7.8.0",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.9.2"
	}
